{
  "name": "ua-ciencias-administrativas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Simulador Inteligente de Experiencias Empresariales y Económicas — Universidad de América",
  "scripts": {
    "dev": "npm-run-all -p dev:client dev:server",
    "dev:server": "node --experimental-sqlite --watch server/index.js",
    "dev:client": "vite build --watch --mode development",
    "build": "vite build",
    "start": "node --experimental-sqlite server/index.js",
    "postinstall": "npm run build"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "npm-run-all": "^4.1.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "vite": "^5.4.10"
  }
}
